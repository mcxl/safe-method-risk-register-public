{
  "name": "safe-method-risk-register",
  "version": "0.0.0",
  "private": true,
  "description": "Safe Method NSW WHS control document pipeline",
  "type": "module",
  "engines": {
    "node": "24.x",
    "npm": ">=11 <12"
  },
  "scripts": {
    "lint": "eslint scripts tests rules generate render app eslint.config.mjs",
    "format:check": "prettier --check package.json tsconfig.json .prettierrc.json scripts tests rules generate render app spec src .github",
    "typecheck": "tsc --noEmit",
    "test": "node --test tests/*.test.mjs",
    "public:secret-scan": "node scripts/public-secret-scan.mjs",
    "verify:public": "npm run public:secret-scan && npm run verify:toolchain && npm run lint && npm run format:check && npm run typecheck && npm run verify:schemas:ajv",
    "verify:toolchain": "node scripts/verify-toolchain.mjs",
    "verify:kb:coverage": "node scripts/run-python.mjs knowledge/coverage_check.py",
    "verify:kb:roundtrip": "node scripts/verify-kb-roundtrip.mjs",
    "verify:kb": "npm run verify:kb:coverage && npm run verify:kb:roundtrip",
    "verify:kb:db": "node scripts/verify-kb-db.mjs",
    "verify:kb:db:docker": "node scripts/verify-kb-db.mjs --docker",
    "verify:schemas:python": "node scripts/run-python.mjs scripts/verify_schemas.py",
    "verify:schemas:ajv": "node scripts/verify-schemas.mjs",
    "verify:schemas:fixtures": "node scripts/verify-schema-fixtures.mjs",
    "verify:schemas": "npm run verify:schemas:python && npm run verify:schemas:ajv && npm run verify:schemas:fixtures",
    "verify:rules": "node scripts/verify-rules.mjs",
    "verify:generation": "node scripts/verify-generation.mjs",
    "verify:generation:api": "node scripts/verify-generation-api.mjs",
    "verify:generation:sectioned": "node scripts/verify-generation-sectioned.mjs",
    "verify:generation:sectioned:provider": "node scripts/verify-generation-sectioned-provider.mjs",
    "verify:generation:sectioned:provider:preflight": "node scripts/verify-sectioned-provider-preflight.mjs",
    "verify:generation:sectioned:anthropic:api": "node scripts/verify-generation-sectioned-anthropic-api.mjs",
    "verify:generation:sectioned:openai:api": "node scripts/verify-generation-sectioned-openai-api.mjs",
    "verify:generation:sectioned:api:preflight": "node scripts/verify-sectioned-live-preflight.mjs",
    "verify:generation:sectioned:api:staged": "node scripts/verify-sectioned-live-preflight.mjs --run-local-gates --run-live --print-worker-roles",
    "verify:generation:sectioned:api": "node scripts/verify-generation-sectioned-api.mjs",
    "generate:sectioned:codex-assisted:prepare": "node scripts/generate-sectioned-codex-assisted-prepare.mjs",
    "generate:sectioned:codex-assisted:lock": "node scripts/generate-sectioned-codex-assisted-lock.mjs",
    "generate:sectioned:codex-assisted:assemble": "node scripts/generate-sectioned-codex-assisted-assemble.mjs",
    "generate:local:draft": "node scripts/generate-local-draft.mjs",
    "verify:local:draft": "node scripts/verify-local-draft.mjs",
    "verify:docx": "node scripts/verify-docx-render.mjs",
    "verify:docx:visual": "node scripts/verify-docx-visual.mjs",
    "verify:xlsx": "node scripts/verify-xlsx-render.mjs",
    "verify:xlsx:libreoffice": "node scripts/verify-xlsx-libreoffice.mjs",
    "verify:xlsx:dashboard": "node scripts/verify-xlsx-dashboard-scenarios.mjs",
    "verify:xlsx:excel": "node scripts/verify-xlsx-excel.mjs",
    "verify:workflow": "node scripts/verify-workflow.mjs",
    "verify:skill-sync": "node scripts/verify-skill-sync.mjs",
    "verify:fixtures": "node scripts/verify-fixtures.mjs --phase 5B",
    "verify:phase5a:evidence": "node scripts/verify-phase5a-evidence.mjs",
    "verify:phase5a:acceptance": "npm run verify:offline && npm run verify:kb:db:docker && npm run verify:docx:visual && npm run verify:phase5a:evidence",
    "verify:phase5b:fixtures": "node scripts/verify-fixtures.mjs --phase 5B",
    "verify:phase5b:evidence": "node scripts/verify-phase5b-evidence.mjs",
    "verify:phase5b:acceptance": "npm run verify:offline && npm run verify:kb:db:docker && npm run verify:xlsx:libreoffice && npm run verify:xlsx:dashboard && npm run verify:xlsx:excel && npm run verify:phase5b:evidence",
    "verify:phase6:evidence": "node scripts/verify-phase6-evidence.mjs",
    "verify:offline": "npm run verify:toolchain && npm run lint && npm run format:check && npm run typecheck && npm run test && npm run verify:kb && npm run verify:schemas && npm run verify:rules && npm run verify:generation && npm run verify:generation:sectioned && npm run verify:docx && npm run verify:xlsx && npm run verify:workflow && npm run verify:fixtures && npm run verify:skill-sync",
    "verify": "npm run verify:offline && npm run verify:kb:db:docker && npm run verify:generation:api",
    "kb:load": "node scripts/load-kb-to-postgres.mjs",
    "kb:export": "node scripts/export-kb-from-postgres.mjs"
  },
  "dependencies": {
    "ajv": "8.20.0",
    "docx": "9.7.1",
    "jszip": "3.10.1",
    "postgres": "3.4.9"
  },
  "devDependencies": {
    "eslint": "10.5.0",
    "prettier": "3.8.4",
    "supabase": "2.107.0",
    "typescript": "6.0.3"
  }
}
